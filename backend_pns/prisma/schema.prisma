// Este é o arquivo prisma/schema.prisma

// Define o "motor" do Prisma
generator client {
  provider = "prisma-client-js"
}

// Aponta para o seu banco de dados (usando a senha do .env)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------
// AQUI COMEÇA A SUA LÓGICA
// ------------------------------------------

// Modelo (Tabela) de Administradores
model Admins {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  nome            String?  // O "?" permite que comece vazio (null)
  senha           String?  // O "?" permite que comece vazio (null)
  nivel           String   // "super_administrador" ou "administrador"
  token_ativacao  String?  @unique
  created_at      DateTime @default(now())
}

// Modelo (Tabela) de Substâncias
model substances {
  id                           Int      @id @default(autoincrement())
  nome                         String   // Ex: "Morfina" (Nome popular ou principal)
  nome_quimico                 String
  formula_molecular            String
  smile                        String  // SMILES string
  propriedades_fisico_quimicas String
  atividade_biologica          String
  origem                       String
  uso_tradicional              String
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt
}